# API de Claude (requerido)
ANTHROPIC_API_KEY=sk-ant-api03-TU-API-KEY-AQUI

# Base de datos PostgreSQL (produccion)
DATABASE_URL=postgresql://usuario:password@localhost:5432/opsagent

# Supabase Auth (produccion)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-supabase-anon-key
SUPABASE_JWT_SECRET=tu-jwt-secret-de-supabase

# Servidor (Railway asigna PORT automaticamente)
PORT=8000
ALLOWED_ORIGINS=http://localhost:8501

# Frontend (URL de la API backend)
OPSAGENT_API_URL=http://localhost:8000
